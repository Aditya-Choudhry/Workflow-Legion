# App
APP_ENV=local
DATABASE_URL=sqlite:///./workflow_legion.db
REDIS_URL=redis://localhost:6379/0

# Primary LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Band Remote Agent Connection
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_API_KEY=
BAND_TRIAGE_AGENT_API_KEY=
BAND_CHAT_ID=
BAND_ROOM_ID=
BAND_DEFAULT_MENTION_HANDLES=redhood

# Band Handles
BAND_TRIAGE_HANDLE=@your-triage-agent
BAND_THREAT_INTEL_HANDLE=@your-threat-intel-agent
BAND_FORENSICS_HANDLE=@your-forensics-agent
BAND_COMPLIANCE_HANDLE=@your-compliance-agent
BAND_COMMANDER_HANDLE=@your-commander-agent

# Band Role Agent API Keys
BAND_THREAT_INTEL_AGENT_API_KEY=
BAND_FORENSICS_AGENT_API_KEY=
BAND_COMPLIANCE_AGENT_API_KEY=
BAND_COMMANDER_AGENT_API_KEY=

# Featherless
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=

# AI/ML API
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini

# Native.Builder / NativelyAI
NATIVE_BUILDER_PROJECT_URL=
NATIVE_BUILDER_NOTES_URL=

# Provider Router
LLM_PROVIDER=aimlapi
LLM_FALLBACK_PROVIDER=featherless
